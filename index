<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>iplan tv — Painel de Gestão</title>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' rx='20' fill='%231a1a2e'/><text y='.9em' font-size='70' x='12'>📺</text></svg>" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #f5f5f0;
      --surface: #ffffff;
      --surface2: #f0efe9;
      --border: #e2e0d8;
      --border2: #cccac0;
      --text: #1a1a1a;
      --text2: #6b6b65;
      --text3: #9b9b95;
      --accent: #1a1a2e;
      --accent2: #252545;
      --red: #e94560;
      --green: #1D9E75;
      --amber: #BA7517;
      --danger: #E24B4A;
      --wpp: #25D366;
      --radius: 10px;
      --radius-sm: 6px;
    }

    body {
      font-family: 'Segoe UI', system-ui, sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
    }

    /* HEADER */
    .topbar {
      background: var(--accent);
      padding: 0 2rem;
      height: 56px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      position: sticky;
      top: 0;
      z-index: 10;
    }
    .topbar-logo { display: flex; align-items: center; gap: 10px; }
    .topbar-logo-icon { width: 32px; height: 32px; background: var(--red); border-radius: 8px; display: flex; align-items: center; justify-content: center; font-size: 16px; }
    .topbar-logo-text { color: #fff; font-size: 16px; font-weight: 600; letter-spacing: 0.3px; }
    .topbar-info { color: rgba(255,255,255,0.5); font-size: 12px; }

    /* LAYOUT */
    .container { max-width: 1200px; margin: 0 auto; padding: 1.5rem 1.5rem; }

    /* TABS */
    .tabs { display: flex; gap: 4px; margin-bottom: 1.5rem; background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 4px; width: fit-content; }
    .tab { padding: 8px 20px; font-size: 13px; font-weight: 500; cursor: pointer; background: none; border: none; color: var(--text2); border-radius: calc(var(--radius) - 2px); display: flex; align-items: center; gap: 6px; transition: all .15s; }
    .tab.active { background: var(--accent); color: #fff; }
    .tab:hover:not(.active) { background: var(--surface2); }

    /* STATS */
    .stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-bottom: 1.5rem; }
    .stat { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 16px; }
    .stat-label { font-size: 12px; color: var(--text2); margin-bottom: 6px; }
    .stat-value { font-size: 28px; font-weight: 700; color: var(--text); }
    .stat-value.green { color: var(--green); }
    .stat-value.amber { color: var(--amber); }
    .stat-value.red { color: var(--danger); }

    /* CARD */
    .card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); margin-bottom: 1.25rem; overflow: hidden; }
    .card-header { padding: 1rem 1.25rem; border-bottom: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 10px; }
    .card-title { font-size: 14px; font-weight: 600; color: var(--text); display: flex; align-items: center; gap: 8px; }
    .card-body { padding: 1.25rem; }

    /* FORM */
    .form-grid { display: grid; grid-template-columns: 1.5fr 1fr 1fr 1fr 140px auto; gap: 10px; align-items: end; }
    .form-grid-tv { display: grid; grid-template-columns: 1.5fr 1fr 1fr auto; gap: 10px; align-items: end; }
    .field { display: flex; flex-direction: column; gap: 5px; }
    .field label { font-size: 12px; font-weight: 500; color: var(--text2); }
    .field input, .field select {
      height: 38px; border: 1px solid var(--border2); border-radius: var(--radius-sm);
      padding: 0 10px; font-size: 14px; color: var(--text); background: var(--surface);
      outline: none; transition: border .15s;
    }
    .field input:focus, .field select:focus { border-color: var(--accent); }
    .field input[readonly] { background: var(--surface2); cursor: not-allowed; color: var(--text2); }
    .hint { font-size: 11px; color: var(--text3); margin-top: 8px; }
    .form-error { font-size: 12px; color: var(--danger); margin-top: 8px; display: none; }

    /* BUTTONS */
    .btn { height: 38px; border: none; border-radius: var(--radius-sm); padding: 0 18px; font-size: 14px; font-weight: 500; cursor: pointer; display: inline-flex; align-items: center; gap: 6px; transition: all .15s; white-space: nowrap; }
    .btn-primary { background: var(--accent); color: #fff; }
    .btn-primary:hover { background: var(--accent2); }
    .btn-wpp-all { background: var(--wpp); color: #fff; }
    .btn-wpp-all:hover { background: #1ebe5d; }
    .btn-danger { background: var(--danger); color: #fff; }
    .btn-cancel-modal { background: var(--surface2); color: var(--text); border: 1px solid var(--border2); }
    .btn-cancel-modal:hover { background: var(--border); }

    /* TOOLBAR */
    .toolbar { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
    .search-wrap { position: relative; }
    .search-wrap svg { position: absolute; left: 10px; top: 50%; transform: translateY(-50%); width: 16px; height: 16px; color: var(--text3); }
    .search-wrap input { padding-left: 34px; width: 200px; }

    /* FILTERS */
    .filter-row { display: flex; gap: 6px; padding: 10px 1.25rem; border-bottom: 1px solid var(--border); flex-wrap: wrap; background: var(--surface2); }
    .fbtn { font-size: 12px; padding: 4px 14px; border-radius: 99px; border: 1px solid var(--border2); background: var(--surface); cursor: pointer; color: var(--text2); transition: all .15s; font-weight: 500; }
    .fbtn.active { background: var(--accent); color: #fff; border-color: var(--accent); }
    .fbtn:hover:not(.active) { background: var(--border); }

    /* TABLE */
    .table-wrap { overflow-x: auto; }
    table { width: 100%; border-collapse: collapse; }
    th { font-size: 12px; font-weight: 600; color: var(--text2); text-align: left; padding: 10px 1.25rem; background: var(--surface2); border-bottom: 1px solid var(--border); text-transform: uppercase; letter-spacing: 0.4px; }
    td { font-size: 13px; color: var(--text); padding: 11px 1.25rem; border-bottom: 1px solid var(--border); vertical-align: middle; }
    tr:last-child td { border-bottom: none; }
    tr:hover td { background: #fafaf7; }

    /* BADGES */
    .badge { display: inline-flex; align-items: center; gap: 4px; font-size: 11px; font-weight: 600; padding: 3px 9px; border-radius: 99px; }
    .badge-mensal { background: #deedf9; color: #185FA5; }
    .badge-trimestral { background: #fdecd4; color: #854F0B; }
    .badge-anual { background: #ddf0e5; color: #1a6b3c; }
    .sbadge { display: inline-flex; align-items: center; gap: 5px; font-size: 11px; font-weight: 600; padding: 4px 10px; border-radius: 99px; }
    .s-ativo { background: #ddf0e5; color: #1a6b3c; }
    .s-vencendo { background: #fdecd4; color: #854F0B; }
    .s-vencido { background: #fde8e8; color: #9b1f1f; }
    .tv-badge { background: #ede8fb; color: #4a35a0; font-size: 11px; font-weight: 600; padding: 3px 9px; border-radius: 99px; display: inline-block; }

    /* DAYS */
    .days-ok { color: var(--green); font-weight: 600; font-size: 13px; }
    .days-warn { color: var(--amber); font-weight: 600; font-size: 13px; }
    .days-danger { color: var(--danger); font-weight: 600; font-size: 13px; }

    /* ACTIONS */
    .actions { display: flex; gap: 5px; }
    .ic { background: none; border: 1px solid var(--border2); border-radius: var(--radius-sm); width: 30px; height: 30px; cursor: pointer; display: flex; align-items: center; justify-content: center; color: var(--text2); transition: all .15s; }
    .ic svg { width: 15px; height: 15px; }
    .ic:hover { background: var(--surface2); color: var(--text); }
    .ic.del { border-color: #f5c0c0; color: var(--danger); }
    .ic.del:hover { background: #fde8e8; }
    .ic.renew { border-color: #b5dfc9; color: var(--green); }
    .ic.renew:hover { background: #ddf0e5; }
    .ic.wpp { border-color: #a5e5bf; color: var(--wpp); }
    .ic.wpp:hover { background: var(--wpp); color: #fff; border-color: var(--wpp); }
    .ic.wpp-off { border-color: var(--border); color: var(--text3); }
    .ic.wpp-off:hover { background: var(--wpp); color: #fff; border-color: var(--wpp); }

    /* EMPTY */
    .empty { text-align: center; padding: 3rem; color: var(--text3); font-size: 14px; }
    .empty-icon { font-size: 40px; margin-bottom: 10px; }

    /* LOADING */
    .loading { text-align: center; padding: 2rem; color: var(--text3); font-size: 14px; }
    .spinner { display: inline-block; width: 20px; height: 20px; border: 2px solid var(--border2); border-top-color: var(--accent); border-radius: 50%; animation: spin .7s linear infinite; margin-right: 8px; vertical-align: middle; }
    @keyframes spin { to { transform: rotate(360deg); } }

    /* TOAST */
    .toast { position: fixed; bottom: 24px; right: 24px; background: var(--accent); color: #fff; padding: 12px 20px; border-radius: var(--radius); font-size: 14px; font-weight: 500; z-index: 999; display: none; animation: fadeup .3s ease; box-shadow: 0 4px 20px rgba(0,0,0,0.15); }
    .toast.error { background: var(--danger); }
    .toast.show { display: block; }
    @keyframes fadeup { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

    /* MODAL */
    .modal-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.45); z-index: 100; align-items: center; justify-content: center; padding: 1rem; }
    .modal-overlay.open { display: flex; }
    .modal { background: var(--surface); border-radius: var(--radius); border: 1px solid var(--border); padding: 1.75rem; width: 420px; max-width: 100%; box-shadow: 0 8px 40px rgba(0,0,0,0.15); }
    .modal-title { font-size: 16px; font-weight: 700; margin-bottom: .75rem; color: var(--text); display: flex; align-items: center; gap: 8px; }
    .modal-msg { font-size: 14px; color: var(--text2); margin-bottom: 1.25rem; line-height: 1.7; }
    .msg-preview { background: var(--surface2); border-radius: var(--radius-sm); padding: 14px; font-size: 13px; color: var(--text); line-height: 1.8; margin-bottom: 1.25rem; border-left: 4px solid var(--wpp); white-space: pre-wrap; }
    .modal-actions { display: flex; gap: 8px; justify-content: flex-end; }
    .phone-field { margin-bottom: 12px; }
    .phone-field label { font-size: 12px; font-weight: 500; color: var(--text2); display: block; margin-bottom: 5px; }
    .phone-field input { width: 100%; height: 38px; border: 1px solid var(--border2); border-radius: var(--radius-sm); padding: 0 10px; font-size: 14px; outline: none; }
    .phone-field input:focus { border-color: var(--wpp); }

    /* RESPONSIVE */
    @media (max-width: 900px) {
      .form-grid { grid-template-columns: 1fr 1fr; }
      .stats { grid-template-columns: repeat(2, 1fr); }
      .form-grid-tv { grid-template-columns: 1fr 1fr; }
    }
    @media (max-width: 600px) {
      .form-grid { grid-template-columns: 1fr; }
      .form-grid-tv { grid-template-columns: 1fr; }
      .stats { grid-template-columns: repeat(2, 1fr); }
      .container { padding: 1rem; }
      .topbar { padding: 0 1rem; }
    }
  </style>
</head>
<body>

<div class="topbar">
  <div class="topbar-logo">
    <div class="topbar-logo-icon">📺</div>
    <span class="topbar-logo-text">iplan tv</span>
  </div>
  <span class="topbar-info" id="sync-status">Conectando...</span>
</div>

<div class="container">

  <div class="tabs">
    <button class="tab active" onclick="setTab('assinantes')" id="tab-assinantes">
      👥 Assinantes
    </button>
    <button class="tab" onclick="setTab('tv')" id="tab-tv">
      📺 Tipos de TV
    </button>
  </div>

  <!-- ABA ASSINANTES -->
  <div id="pane-assinantes">

    <div class="stats" id="stats">
      <div class="stat"><div class="stat-label">Total</div><div class="stat-value" id="s-total">—</div></div>
      <div class="stat"><div class="stat-label">Ativos</div><div class="stat-value green" id="s-ativos">—</div></div>
      <div class="stat"><div class="stat-label">Vencendo em breve</div><div class="stat-value amber" id="s-vencendo">—</div></div>
      <div class="stat"><div class="stat-label">Vencidos</div><div class="stat-value red" id="s-vencidos">—</div></div>
    </div>

    <div class="card">
      <div class="card-header">
        <div class="card-title">➕ Nova assinatura</div>
      </div>
      <div class="card-body">
        <div class="form-grid">
          <div class="field">
            <label>Nome do cliente</label>
            <input type="text" id="inp-nome" placeholder="Ex: João Silva" />
          </div>
          <div class="field">
            <label>Plano</label>
            <select id="inp-plano">
