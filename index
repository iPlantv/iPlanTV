      </div>
      <div class="filter-row" id="filter-row"></div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Cliente</th>
              <th>Plano</th>
              <th>Início</th>
              <th>Vencimento</th>
              <th>Dias restantes</th>
              <th>Status</th>
              <th>Ações</th>
            </tr>
          </thead>
          <tbody id="table-body">
            <tr><td colspan="7"><div class="loading"><span class="spinner"></span>Carregando...</div></td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <!-- ABA TIPOS DE TV -->
  <div id="pane-tv" style="display:none;">
    <div class="card">
      <div class="card-header">
        <div class="card-title">➕ Cadastrar tipo de TV</div>
      </div>
      <div class="card-body">
        <div class="form-grid-tv">
          <div class="field">
            <label>Nome / Modelo</label>
            <input type="text" id="tv-nome" placeholder="Ex: Samsung Smart TV 55'" />
          </div>
          <div class="field">
            <label>Marca</label>
            <input type="text" id="tv-marca" placeholder="Ex: Samsung" />
          </div>
          <div class="field">
            <label>Categoria</label>
            <select id="tv-cat">
              <option value="Smart TV">Smart TV</option>
              <option value="Android TV">Android TV</option>
              <option value="TV Box">TV Box</option>
              <option value="Firestick">Firestick</option>
              <option value="Roku">Roku</option>
              <option value="Outro">Outro</option>
            </select>
          </div>
          <button class="btn btn-primary" onclick="addTipoTV()">+ Adicionar</button>
        </div>
        <div class="form-error" id="err-tv"></div>
      </div>
    </div>

    <div class="card">
      <div class="card-header">
        <div class="card-title">📺 Tipos cadastrados <span id="tv-count" style="font-size:12px;font-weight:400;color:var(--text2);"></span></div>
        <div class="search-wrap">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          <input type="text" id="tv-search" placeholder="Buscar tipo..." oninput="renderTVs()" />
        </div>
      </div>
      <div class="table-wrap">
        <table>
          <thead>
            <tr><th>Nome / Modelo</th><th>Marca</th><th>Categoria</th><th>Ações</th></tr>
          </thead>
          <tbody id="tv-body">
            <tr><td colspan="4"><div class="loading"><span class="spinner"></span>Carregando...</div></td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>

</div>

<!-- MODAIS -->
<div class="modal-overlay" id="modal-wpp">
  <div class="modal">
    <div class="modal-title">💬 Enviar mensagem WhatsApp</div>
    <div class="modal-msg" id="wpp-info"></div>
    <div id="phone-section">
      <div class="phone-field">
        <label>Número do WhatsApp</label>
        <input type="text" id="modal-phone" placeholder="5535999990000" />
      </div>
      <div class="hint" style="margin-bottom:12px;">Código do país + DDD + número, sem espaços.</div>
    </div>
    <div class="msg-preview" id="wpp-msg"></div>
    <div class="modal-actions">
      <button class="btn btn-cancel-modal" onclick="closeModal('modal-wpp')">Cancelar</button>
      <button class="btn btn-wpp-all" id="wpp-confirm">📲 Abrir WhatsApp</button>
    </div>
  </div>
</div>

<div class="modal-overlay" id="modal-del">
  <div class="modal">
    <div class="modal-title">🗑️ Remover assinante</div>
    <div class="modal-msg" id="del-msg"></div>
    <div class="modal-actions">
      <button class="btn btn-cancel-modal" onclick="closeModal('modal-del')">Cancelar</button>
      <button class="btn btn-danger" id="del-confirm">Remover</button>
    </div>
  </div>
</div>

<div class="modal-overlay" id="modal-renew">
  <div class="modal">
    <div class="modal-title">🔄 Renovar assinatura</div>
    <div class="modal-msg" id="renew-msg"></div>
    <div class="modal-actions">
      <button class="btn btn-cancel-modal" onclick="closeModal('modal-renew')">Cancelar</button>
      <button class="btn btn-primary" id="renew-confirm">Renovar</button>
    </div>
  </div>
</div>

<div class="modal-overlay" id="modal-del-tv">
  <div class="modal">
    <div class="modal-title">🗑️ Remover tipo de TV</div>
    <div class="modal-msg" id="del-tv-msg"></div>
    <div class="modal-actions">
      <button class="btn btn-cancel-modal" onclick="closeModal('modal-del-tv')">Cancelar</button>
      <button class="btn btn-danger" id="del-tv-confirm">Remover</button>
    </div>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
  // =============================================
  // CONFIGURAÇÃO SUPABASE
  // =============================================
  const SUPABASE_URL = 'https://vewtojqgusiljhrnsudn.supabase.co';
  const SUPABASE_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InZld3RvanFndXNpbGpocm5zdWRuIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzgxNzM3MTQsImV4cCI6MjA5Mzc0OTcxNH0.7OGUucjaHxCHrcHLeW90s7nO9NJnDLuQ0KBl4QmFzbk';

  const api = (path, opts = {}) => fetch(`${SUPABASE_URL}/rest/v1/${path}`, {
    headers: {
      'apikey': SUPABASE_KEY,
      'Authorization': `Bearer ${SUPABASE_KEY}`,
      'Content-Type': 'application/json',
      'Prefer': opts.prefer || 'return=representation',
      ...opts.headers
    },
    ...opts
  });

  // =============================================
  // UTILITÁRIOS
  // =============================================
  const planoMeses = { mensal: 1, trimestral: 3, anual: 12 };
  const planoLabel = { mensal: 'Mensal', trimestral: 'Trimestral', anual: 'Anual' };

  function today() { return new Date().toISOString().split('T')[0]; }

  function addMonths(dateStr, months) {
    const d = new Date(dateStr + 'T00:00:00');
    d.setMonth(d.getMonth() + months);
    return d.toISOString().split('T')[0];
  }

  function fmt(s) {
    if (!s) return '—';
    const [y, m, d] = s.split('-');
    return `${d}/${m}/${y}`;
  }

  function diffDays(s) {
    const t = new Date(); t.setHours(0, 0, 0, 0);
    return Math.round((new Date(s + 'T00:00:00') - t) / 86400000);
  }

  function getStatus(venc) {
    const d = diffDays(venc);
    if (d < 0) return 'vencido';
    if (d <= 7) return 'vencendo';
    return 'ativo';
  }

  function showToast(msg, type = '') {
    const t = document.getElementById('toast');
    t.textContent = msg;
    t.className = 'toast show' + (type ? ' ' + type : '');
    setTimeout(() => t.className = 'toast', 3000);
  }

  function showErr(id, msg) {
    const el = document.getElementById(id);
    el.textContent = msg;
    el.style.display = 'block';
    setTimeout(() => el.style.display = 'none', 3500);
  }

  function closeModal(id) { document.getElementById(id).classList.remove('open'); }
  document.querySelectorAll('.modal-overlay').forEach(m =>
    m.addEventListener('click', e => { if (e.target === m) m.classList.remove('open'); })
  );

  // =============================================
  // DADOS
  // =============================================
  let assinantes = [];
  let tiposTV = [];
  let filtro = 'todos';

  async function loadAssinantes() {
    try {
      const r = await api('assinantes?select=*&order=venc.asc');
      if (r.ok) {
        assinantes = await r.json();
        document.getElementById('sync-status').textContent = 'Conectado ✓';
      } else {
        document.getElementById('sync-status').textContent = 'Erro de conexão';
      }
    } catch(e) {
      document.getElementById('sync-status').textContent = 'Sem conexão';
    }
  }

  async function loadTVs() {
    try {
      const r = await api('tipos_tv?select=*&order=nome.asc');
      if (r.ok) tiposTV = await r.json();
    } catch(e) {}
  }

  // =============================================
  // ASSINANTES — CRUD
  // =============================================
  async function addAssinante() {
    const nome = document.getElementById('inp-nome').value.trim();
    const plano = document.getElementById('inp-plano').value;
    const inicio = document.getElementById('inp-inicio').value;
    const fone = document.getElementById('inp-fone').value.replace(/\D/g, '');

    if (!nome) return showErr('err-assinante', 'Informe o nome do cliente.');
    if (!inicio) return showErr('err-assinante', 'Informe a data de início.');

    const venc = addMonths(inicio, planoMeses[plano]);
    const r = await api('assinantes', {
      method: 'POST',
      body: JSON.stringify({ nome, plano, inicio, venc, fone: fone || '' })
    });

    if (r.ok) {
      showToast('✅ Assinante adicionado!');
      ['inp-nome', 'inp-inicio', 'inp-venc', 'inp-fone'].forEach(id => document.getElementById(id).value = '');
      await loadAssinantes();
      renderAssinantes();
      renderStats();
    } else {
      showToast('Erro ao salvar. Tente novamente.', 'error');
    }
  }

  async function deleteAssinante(id) {
    const r = await api(`assinantes?id=eq.${id}`, { method: 'DELETE', prefer: 'return=minimal' });
    if (r.ok) {
      assinantes = assinantes.filter(a => a.id !== id);
      showToast('🗑️ Assinante removido.');
      renderAssinantes();
      renderStats();
    } else {
      showToast('Erro ao remover.', 'error');
    }
    closeModal('modal-del');
  }

  async function renovarAssinante(id, novoVenc) {
    const r = await api(`assinantes?id=eq.${id}`, {
      method: 'PATCH',
      body: JSON.stringify({ venc: novoVenc })
    });
    if (r.ok) {
      const a = assinantes.find(x => x.id === id);
      if (a) a.venc = novoVenc;
      showToast('🔄 Assinatura renovada!');
      renderAssinantes();
      renderStats();
    } else {
      showToast('Erro ao renovar.', 'error');
    }
    closeModal('modal-renew');
  }

  async function salvarFone(id, fone) {
    await api(`assinantes?id=eq.${id}`, {
      method: 'PATCH',
      body: JSON.stringify({ fone })
    });
    const a = assinantes.find(x => x.id === id);
    if (a) a.fone = fone;
  }

  // =============================================
  // TIPOS TV — CRUD
  // =============================================
  async function addTipoTV() {
    const nome = document.getElementById('tv-nome').value.trim();
    const marca = document.getElementById('tv-marca').value.trim();
    const cat = document.getElementById('tv-cat').value;
    if (!nome) return showErr('err-tv', 'Informe o nome ou modelo.');

    const r = await api('tipos_tv', {
      method: 'POST',
      body: JSON.stringify({ nome, marca, cat })
    });
    if (r.ok) {
      showToast('✅ Tipo de TV adicionado!');
      document.getElementById('tv-nome').value = '';
      document.getElementById('tv-marca').value = '';
      await loadTVs();
      renderTVs();
    } else {
      showToast('Erro ao salvar.', 'error');
    }
  }

  async function deleteTipoTV(id) {
    const r = await api(`tipos_tv?id=eq.${id}`, { method: 'DELETE', prefer: 'return=minimal' });
    if (r.ok) {
      tiposTV = tiposTV.filter(t => t.id !== id);
      showToast('🗑️ Tipo removido.');
      renderTVs();
    }
    closeModal('modal-del-tv');
  }

  // =============================================
  // WHATSAPP
  // =============================================
  function buildMsg(a) {
    const s = getStatus(a.venc);
    const d = diffDays(a.venc);
    const nome = a.nome.split(' ')[0];
    const plano = planoLabel[a.plano].toLowerCase();

    if (s === 'vencido')
      return `Olá, ${nome}! 👋\n\nPassando para avisar que sua assinatura *iplan tv* (plano ${plano}) *venceu há ${Math.abs(d)} dia${Math.abs(d) !== 1 ? 's' : ''}*.\n\nRenove agora para continuar assistindo! 📺\n\nEstamos à disposição. 😊`;
    if (s === 'vencendo') {
      const t = d === 0 ? '*vence hoje*' : d === 1 ? '*vence amanhã*' : `*vence em ${d} dias* (${fmt(a.venc)})`;
      return `Olá, ${nome}! 👋\n\nLembrete: sua assinatura *iplan tv* (plano ${plano}) ${t}.\n\nRenove para não perder o acesso! 📺\n\nEstamos à disposição. 😊`;
    }
    return `Olá, ${nome}! 👋\n\nSua assinatura *iplan tv* (plano ${plano}) está ativa até ${fmt(a.venc)}. Qualquer dúvida, fale conosco! 😊📺`;
  }

  function openWpp(id) {
    const a = assinantes.find(x => x.id === id);
    if (!a) return;
    const msg = buildMsg(a);
    document.getElementById('wpp-info').textContent = `Cliente: ${a.nome}`;
    document.getElementById('wpp-msg').textContent = msg;
    const ps = document.getElementById('phone-section');
    const pi = document.getElementById('modal-phone');
    ps.style.display = a.fone ? 'none' : 'block';
    if (!a.fone) pi.value = '';

    document.getElementById('wpp-confirm').onclick = async () => {
      const ph = a.fone || pi.value.replace(/\D/g, '');
      if (!ph) { pi.style.borderColor = 'var(--danger)'; pi.focus(); return; }
      if (!a.fone) await salvarFone(id, ph);
      window.open(`https://wa.me/${ph}?text=${encodeURIComponent(msg)}`, '_blank');
      closeModal('modal-wpp');
      renderAssinantes();
    };
    document.getElementById('modal-wpp').classList.add('open');
  }

  function sendAll() {
    const v = assinantes.filter(a => getStatus(a.venc) === 'vencendo' || getStatus(a.venc) === 'vencido');
    if (!v.length) { showToast('Nenhum assinante vencendo ou vencido.'); return; }
    const c = v.filter(a => a.fone);
    if (!confirm(`Notificar ${v.length} assinante(s)?\n\nCom WhatsApp: ${c.length}\nSem WhatsApp: ${v.length - c.length}\n\nAbrir para todos com número cadastrado?`)) return;
    c.forEach((a, i) => setTimeout(() =>
      window.open(`https://wa.me/${a.fone}?text=${encodeURIComponent(buildMsg(a))}`, '_blank'), i * 900)
    );
  }

  // =============================================
  // MODAIS
  // =============================================
  function openDel(id) {
    const a = assinantes.find(x => x.id === id);
    if (!a) return;
    document.getElementById('del-msg').textContent = `Tem certeza que deseja remover "${a.nome}"? Esta ação não pode ser desfeita.`;
    document.getElementById('del-confirm').onclick = () => deleteAssinante(id);
    document.getElementById('modal-del').classList.add('open');
  }

  function openRenew(id) {
    const a = assinantes.find(x => x.id === id);
    if (!a) return;
    const base = a.venc < today() ? today() : a.venc;
    const novoVenc = addMonths(base, planoMeses[a.plano]);
    document.getElementById('renew-msg').textContent = `Renovar assinatura ${planoLabel[a.plano]} de ${a.nome}?\n\nNovo vencimento: ${fmt(novoVenc)}`;
    document.getElementById('renew-confirm').onclick = () => renovarAssinante(id, novoVenc);
    document.getElementById('modal-renew').classList.add('open');
  }

  function openDelTV(id) {
    const tv = tiposTV.find(x => x.id === id);
    if (!tv) return;
    document.getElementById('del-tv-msg').textContent = `Remover o tipo "${tv.nome}"? Esta ação não pode ser desfeita.`;
    document.getElementById('del-tv-confirm').onclick = () => deleteTipoTV(id);
    document.getElementById('modal-del-tv').classList.add('open');
  }

  // =============================================
  // RENDER
  // =============================================
  function setTab(t) {
    ['assinantes', 'tv'].forEach(x => {
      document.getElementById('pane-' + x).style.display = x === t ? 'block' : 'none';
      document.getElementById('tab-' + x).classList.toggle('active', x === t);
    });
  }

  function renderStats() {
    const total = assinantes.length;
    const ativos = assinantes.filter(a => getStatus(a.venc) === 'ativo').length;
    const vencendo = assinantes.filter(a => getStatus(a.venc) === 'vencendo').length;
    const vencidos = assinantes.filter(a => getStatus(a.venc) === 'vencido').length;
    document.getElementById('s-total').textContent = total;
    document.getElementById('s-ativos').textContent = ativos;
    document.getElementById('s-vencendo').textContent = vencendo;
    document.getElementById('s-vencidos').textContent = vencidos;
  }

  function renderFilters() {
    const fs = [
      { k: 'todos', l: 'Todos' }, { k: 'ativo', l: 'Ativos' },
      { k: 'vencendo', l: 'Vencendo' }, { k: 'vencido', l: 'Vencidos' },
      { k: 'mensal', l: 'Mensal' }, { k: 'trimestral', l: 'Trimestral' }, { k: 'anual', l: 'Anual' }
    ];
    document.getElementById('filter-row').innerHTML = fs.map(f =>
      `<button class="fbtn ${filtro === f.k ? 'active' : ''}" onclick="setFiltro('${f.k}')">${f.l}</button>`
    ).join('');
  }

  function setFiltro(k) { filtro = k; renderFilters(); renderAssinantes(); }

  function renderAssinantes() {
    const q = document.getElementById('search-inp').value.toLowerCase();
    let list = assinantes.filter(a => a.nome.toLowerCase().includes(q));
    if (filtro === 'ativo') list = list.filter(a => getStatus(a.venc) === 'ativo');
    else if (filtro === 'vencendo') list = list.filter(a => getStatus(a.venc) === 'vencendo');
    else if (filtro === 'vencido') list = list.filter(a => getStatus(a.venc) === 'vencido');
    else if (['mensal', 'trimestral', 'anual'].includes(filtro)) list = list.filter(a => a.plano === filtro);
    list.sort((a, b) => diffDays(a.venc) - diffDays(b.venc));

    document.getElementById('count-badge').textContent = `(${list.length})`;
    const tb = document.getElementById('table-body');

    if (!list.length) {
      tb.innerHTML = `<tr><td colspan="7"><div class="empty"><div class="empty-icon">👥</div>Nenhum assinante encontrado</div></td></tr>`;
      return;
    }

    tb.innerHTML = list.map(a => {
      const s = getStatus(a.venc);
      const d = diffDays(a.venc);
      let dt, dc;
      if (d < 0) { dt = `${Math.abs(d)}d em atraso`; dc = 'days-danger'; }
      else if (d === 0) { dt = 'Vence hoje'; dc = 'days-danger'; }
      else if (d === 1) { dt = 'Amanhã'; dc = 'days-warn'; }
      else { dt = `${d} dias`; dc = d <= 7 ? 'days-warn' : 'days-ok'; }

      const sm = {
        ativo: ['s-ativo', '✅', 'Ativo'],
        vencendo: ['s-vencendo', '⚠️', 'Vencendo'],
        vencido: ['s-vencido', '❌', 'Vencido']
      };
      const [sc, si, sl] = sm[s];
      const pc = { mensal: 'badge-mensal', trimestral: 'badge-trimestral', anual: 'badge-anual' }[a.plano];
      const wc = a.fone ? 'wpp' : 'wpp-off';

      return `<tr>
        <td>
          <div style="font-weight:600;">${a.nome}</div>
          ${a.fone ? `<div style="font-size:11px;color:var(--text3);">${a.fone}</div>` : ''}
        </td>
        <td><span class="badge ${pc}">${planoLabel[a.plano]}</span></td>
        <td>${fmt(a.inicio)}</td>
        <td>${fmt(a.venc)}</td>
        <td><span class="${dc}">${dt}</span></td>
        <td><span class="sbadge ${sc}">${si} ${sl}</span></td>
        <td>
          <div class="actions">
            <button class="ic ${wc}" title="WhatsApp" onclick="openWpp(${a.id})">
              <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M11.998 2C6.477 2 2 6.477 2 12c0 1.738.457 3.47 1.328 5l-1.316 4.799 4.939-1.296A9.96 9.96 0 0012 22c5.522 0 10-4.477 10-10S17.52 2 11.998 2zm.002 18c-1.612 0-3.14-.438-4.45-1.234l-.32-.189-3.276.859.875-3.194-.205-.332A7.946 7.946 0 014 12c0-4.411 3.589-8 8-8s8 3.589 8 8-3.589 8-8 8z"/></svg>
            </button>
            <button class="ic renew" title="Renovar" onclick="openRenew(${a.id})">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>
            </button>
            <button class="ic del" title="Remover" onclick="openDel(${a.id})">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6 18.1 19a2 2 0 0 1-2 1.9H7.9a2 2 0 0 1-2-1.9L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
            </button>
          </div>
        </td>
      </tr>`;
    }).join('');
  }

  function renderTVs() {
    const q = document.getElementById('tv-search').value.toLowerCase();
    let list = tiposTV.filter(t =>
      t.nome.toLowerCase().includes(q) || t.marca.toLowerCase().includes(q) || t.cat.toLowerCase().includes(q)
    );
    document.getElementById('tv-count').textContent = `(${list.length})`;
    const tb = document.getElementById('tv-body');
    if (!list.length) {
      tb.innerHTML = `<tr><td colspan="4"><div class="empty"><div class="empty-icon">📺</div>Nenhum tipo cadastrado</div></td></tr>`;
      return;
    }
    tb.innerHTML = list.map(t => `<tr>
      <td style="font-weight:600;">${t.nome}</td>
      <td>${t.marca || '—'}</td>
      <td><span class="tv-badge">${t.cat}</span></td>
      <td>
        <button class="ic del" title="Remover" onclick="openDelTV(${t.id})">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6 18.1 19a2 2 0 0 1-2 1.9H7.9a2 2 0 0 1-2-1.9L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
        </button>
      </td>
    </tr>`).join('');
  }

  // =============================================
  // AUTO CALCULAR VENCIMENTO
  // =============================================
  document.getElementById('inp-inicio').addEventListener('change', calcVenc);
  document.getElementById('inp-plano').addEventListener('change', calcVenc);
  function calcVenc() {
    const i = document.getElementById('inp-inicio').value;
    const p = document.getElementById('inp-plano').value;
    if (i) document.getElementById('inp-venc').value = addMonths(i, planoMeses[p]);
  }

  // =============================================
  // INICIALIZAR
  // =============================================
  document.getElementById('inp-inicio').value = today();
  calcVenc();

  async function init() {
    await Promise.all([loadAssinantes(), loadTVs()]);
    renderStats();
    renderFilters();
    renderAssinantes();
    renderTVs();
  }

  init();
</script>
</body>
</html>
