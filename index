    </div>

    <div class="card">
      <div class="card-header">
        <div class="card-title">👥 Assinantes <span id="count-badge" style="font-size:12px;font-weight:400;color:var(--text2);"></span></div>
        <div class="toolbar">
          <button class="btn btn-wpp-all" onclick="sendAll()">📲 Avisar vencendo</button>
          <div class="search-wrap">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
